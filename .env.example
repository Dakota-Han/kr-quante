ENVIRONMENT=local
LOG_LEVEL=INFO

# Kiwoom REST API
KIWOOM_MODE=mock
KIWOOM_BASE_URL=https://mockapi.kiwoom.com
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_ACCOUNT_NO=

# Trading controls
ALLOW_LIVE_TRADING=false
REQUIRE_MANUAL_APPROVAL=true
DISALLOW_MARKET_ORDERS=true
MAX_DAILY_TRADES=1
BASE_CURRENCY=KRW

# Risk defaults
RISK_PER_TRADE=0.003
DAILY_LOSS_LIMIT=-0.006
WEEKLY_LOSS_LIMIT=-0.015
MONTHLY_LOSS_LIMIT=-0.04

# Dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
